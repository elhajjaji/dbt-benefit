# Copier vers .env puis adapter.
# Profils démarrés par défaut avec `docker compose up -d` :
COMPOSE_PROFILES=lakehouse,ingestion,bi,lineage

# ── Base source PostgreSQL (schéma src) ──────────────────────────────────────
# Elle est DÉJÀ disponible via les conteneurs pocs-postgres (port hôte 5433)
# et pocs-pgadmin (http://localhost:5050) du repository benefits-dataset.
# Le service postgres du docker-compose.yml n'est qu'un secours si ces
# conteneurs ne tournent pas (dans ce cas : port 5432, app/app_secret).
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=pocs
SOURCE_CONTAINER=pocs-postgres

# MinIO
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio_secret

# NiFi (mot de passe : 12 caractères minimum)
NIFI_USER=admin
NIFI_PASSWORD=admin12345678

# dbt (repris par dbt/profiles.yml via env_var)
DBT_HOST=localhost
DBT_PORT=5433
DBT_USER=user
DBT_PASSWORD=password
DBT_DBNAME=pocs

# OpenLineage (utilisé par dbt-ol)
OPENLINEAGE_URL=http://localhost:5000
OPENLINEAGE_NAMESPACE=benefits
